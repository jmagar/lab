# lab — environment configuration
#
# Copy to ~/.lab/.env and fill in. Only services you actually use need values;
# unset services are skipped at runtime by `lab serve` / `lab health`.
#
# Naming convention:
#   {SERVICE}_URL       — base URL (no trailing slash)
#   {SERVICE}_API_KEY   — for ApiKey auth
#   {SERVICE}_TOKEN     — for Bearer/Token auth
#   {SERVICE}_USERNAME  — for Basic auth
#   {SERVICE}_PASSWORD  — for Basic auth

# ─── lab MCP server ───────────────────────────────────────────────────────────
# Transport: "stdio" (default for Claude Desktop / .mcp.json) or "http" (network)
LAB_MCP_TRANSPORT=stdio

# HTTP transport settings (only used when LAB_MCP_TRANSPORT=http)
LAB_MCP_HTTP_HOST=127.0.0.1
LAB_MCP_HTTP_PORT=8400
# Bearer token required on every HTTP request. Generate with: openssl rand -hex 32
LAB_MCP_HTTP_TOKEN=
# CORS allow-list, comma-separated origins. Empty = no CORS headers.
LAB_MCP_HTTP_CORS_ORIGINS=

# Comma-separated services to expose. "all" enables every configured service.
LAB_MCP_SERVICES=all

# Elicitation policy for destructive ops (arcane, unraid, qbittorrent delete, etc.)
#   "always"  — prompt every destructive call (safest)
#   "session" — prompt once per session per action (default)
#   "never"   — auto-confirm (NOT recommended; use only for trusted automation)
LAB_MCP_ELICIT=session

# CLI confirmation policy mirrors MCP elicitation
#   "always" | "session" | "never"
# Override per-call with --yes / -y to skip, or --no-confirm to fail loudly.
LAB_CLI_CONFIRM=always

# Logging
LAB_LOG=info                # tracing filter: trace|debug|info|warn|error
LAB_LOG_FORMAT=fmt          # fmt | json

# ─── Servarr stack ────────────────────────────────────────────────────────────
