{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/schemas/codex-marketplace.schema.json",
  "title": "Codex marketplace manifest (.agents/plugins/marketplace.json)",
  "description": "Synthesized from the upstream RawMarketplaceManifest types at codex-rs/core-plugins/src/marketplace.rs (OpenAI Codex repo). Last verified against the type def — when Codex publishes their own JSON Schema, replace this file via refresh-schemas.sh.",
  "type": "object",
  "required": ["name", "plugins"],
  "additionalProperties": true,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "interface": {
      "type": "object",
      "description": "Optional marketplace-level metadata.",
      "properties": {
        "displayName": { "type": "string" }
      },
      "additionalProperties": true
    },
    "plugins": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "source"],
        "additionalProperties": true,
        "properties": {
          "name":     { "type": "string", "minLength": 1 },
          "category": { "type": "string" },
          "source": {
            "description": "Can be a bare string path or a tagged object with `source: 'local' | 'url' | 'git-subdir'`. The bare string form is shorthand for a Path source.",
            "oneOf": [
              { "type": "string", "description": "Bare path form — convenience for local sources." },
              {
                "type": "object",
                "required": ["source"],
                "properties": {
                  "source": { "const": "local" },
                  "path":   { "type": "string", "minLength": 1 }
                },
                "additionalProperties": true
              },
              {
                "type": "object",
                "required": ["source", "url"],
                "properties": {
                  "source": { "const": "url" },
                  "url":    { "type": "string", "format": "uri" },
                  "path":   { "type": "string" },
                  "ref":    { "type": "string", "description": "Git ref (branch, tag, etc.)." },
                  "sha":    { "type": "string", "description": "Pinned commit SHA." }
                },
                "additionalProperties": true
              },
              {
                "type": "object",
                "required": ["source", "url"],
                "properties": {
                  "source": { "const": "git-subdir" },
                  "url":    { "type": "string", "format": "uri" }
                },
                "additionalProperties": true
              }
            ]
          },
          "policy": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "installation": {
                "type": "string",
                "enum": ["NOT_AVAILABLE", "AVAILABLE", "INSTALLED_BY_DEFAULT"],
                "description": "Default: AVAILABLE."
              },
              "authentication": {
                "type": "string",
                "enum": ["ON_INSTALL", "ON_USE"],
                "description": "Default: ON_INSTALL."
              },
              "products": {
                "type": "array",
                "description": "Optional product gating list — opaque to this schema; carried through marketplace metadata.",
                "items": { "type": "object" }
              }
            }
          }
        }
      }
    }
  }
}
