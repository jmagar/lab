FROM ubuntu:24.04
RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates && rm -rf /var/lib/apt/lists/*
RUN mkdir -p /home/lab/.config/lab /home/lab/.local/state/lab /home/lab/.local/share/lab && chown -R 1000:1000 /home/lab
COPY bin/lab /usr/local/bin/lab
RUN chmod +x /usr/local/bin/lab
ENV HOME=/home/lab
USER 1000:1000
WORKDIR /home/lab
EXPOSE 8765
ENTRYPOINT ["/usr/local/bin/lab"]
CMD ["serve"]
